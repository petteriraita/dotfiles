#!/usr/bin/env bash
set -euo pipefail

POSTSWITCH_BIN="${POSTSWITCH_BIN:-$HOME/.config/display/postswitch}"
LIBINPUT_BIN="${LIBINPUT_BIN:-libinput}"
GDBUS_BIN="${GDBUS_BIN:-gdbus}"
LID_DEVICE_NAME="${LID_DEVICE_NAME:-Lid Switch}"
SUSPEND_FLAG_FILE="${SUSPEND_FLAG_FILE:-/tmp/display_suspend_in_progress}"

find_lid_device() {
    local name_file=""
    local event_name=""

    for name_file in /sys/class/input/event*/device/name; do
        [[ -r "$name_file" ]] || continue
        if grep -qx "$LID_DEVICE_NAME" "$name_file"; then
            event_name="$(basename "$(dirname "$(dirname "$name_file")")")"
            printf '/dev/input/%s\n' "$event_name"
            return 0
        fi
    done

    return 1
}

main() {
    local lid_device=""
    local lid_pid=""
    local resume_pid=""

    lid_device="$(find_lid_device)" || exit 1
    rm -f "$SUSPEND_FLAG_FILE"
    "$POSTSWITCH_BIN" || true

    stdbuf -oL "$LIBINPUT_BIN" debug-events --device "$lid_device" 2>/dev/null |
        while IFS= read -r _line; do
            sleep 0.2
            "$POSTSWITCH_BIN" || true
        done &
    lid_pid=$!

    "$GDBUS_BIN" monitor --system --dest org.freedesktop.login1 2>/dev/null |
        while IFS= read -r line; do
            if [[ "$line" == *"PrepareForSleep"* ]]; then
                while IFS= read -r state_line; do
                    if [[ "$state_line" == *"boolean true"* ]]; then
                        : >"$SUSPEND_FLAG_FILE"
                        break
                    fi
                    if [[ "$state_line" == *"boolean false"* ]]; then
                        rm -f "$SUSPEND_FLAG_FILE"
                        sleep 1
                        "$POSTSWITCH_BIN" || true
                        break
                    fi
                    [[ "$state_line" == *"boolean "* ]] && break
                done
            fi
        done &
    resume_pid=$!

    wait "$lid_pid" "$resume_pid"
}

main "$@"
