#!/usr/bin/env bash
set -euo pipefail

INTERNAL="${INTERNAL:-eDP-1}"
STATE_FILE="${STATE_FILE:-/tmp/display_state}"
LOCK_FILE="${LOCK_FILE:-/tmp/display_postswitch.lock}"
NOTIFY_BIN="${NOTIFY_BIN:-safenotify.sh}"
XRANDR_BIN="${XRANDR_BIN:-xrandr}"
I3MSG_BIN="${I3MSG_BIN:-i3-msg}"
JQ_BIN="${JQ_BIN:-jq}"
DRM_STATUS_GLOB="${DRM_STATUS_GLOB:-/sys/class/drm/card*-*/status}"
LID_STATE_FILE="${LID_STATE_FILE:-/proc/acpi/button/lid/LID/state}"
SUSPEND_FLAG_FILE="${SUSPEND_FLAG_FILE:-/tmp/display_suspend_in_progress}"

POLL_INTERVAL="${POLL_INTERVAL:-0.5}"
STABLE_SAMPLES="${STABLE_SAMPLES:-3}"
XRANDR_READY_ATTEMPTS="${XRANDR_READY_ATTEMPTS:-6}"
XRANDR_APPLY_ATTEMPTS="${XRANDR_APPLY_ATTEMPTS:-4}"
DISCONNECT_GRACE_SAMPLES="${DISCONNECT_GRACE_SAMPLES:-6}"
I3_DISCOVERY_ATTEMPTS="${I3_DISCOVERY_ATTEMPTS:-6}"

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    "$NOTIFY_BIN" "DISPLAY CONNECTION: postswitch already running"
    exit 0
fi

log() {
    "$NOTIFY_BIN" "$1"
}

read_state() {
    cat "$STATE_FILE" 2>/dev/null || echo "unset"
}

write_state() {
    printf '%s\n' "$1" >"$STATE_FILE"
}

sleep_transition_in_progress() {
    [[ -e "$SUSPEND_FLAG_FILE" ]]
}

has_x_session() {
    [[ -n "${DISPLAY:-}" ]] && [[ -S "${XAUTHORITY:-/nonexistent}" || -f "${XAUTHORITY:-/nonexistent}" ]]
}

run_retry() {
    local attempts="$1"
    shift
    local try

    for ((try = 1; try <= attempts; try++)); do
        if "$@"; then
            return 0
        fi
        sleep "$POLL_INTERVAL"
    done

    return 1
}

current_signature() {
    local connectors=()
    local status_file=""
    local connector=""

    for status_file in $DRM_STATUS_GLOB; do
        [[ -e "$status_file" ]] || continue
        if grep -qx connected "$status_file"; then
            connector="${status_file%/status}"
            connector="${connector##*/}"
            if [[ "$connector" != *"$INTERNAL"* ]]; then
                connectors+=("$connector")
            fi
        fi
    done

    if ((${#connectors[@]} == 0)); then
        printf '%s\n' "internal-only"
        return
    fi

    printf '%s\n' "${connectors[@]}" | sort | paste -sd ',' -
}

lid_state() {
    if [[ -r "$LID_STATE_FILE" ]]; then
        awk '/state:/ {print $2}' "$LID_STATE_FILE"
        return
    fi

    printf '%s\n' "open"
}

current_mode() {
    local signature=""
    local lid=""

    signature="$(current_signature)"
    lid="$(lid_state)"

    if [[ "$signature" == "internal-only" ]]; then
        printf '%s\n' "mobile"
        return
    fi

    if [[ "$lid" == "closed" ]]; then
        printf '%s\n' "clamshell:$signature"
    else
        printf '%s\n' "docked:$signature"
    fi
}

wait_for_stable_mode() {
    local previous="__unset__"
    local current=""
    local stable=0
    local try

    for ((try = 1; try <= 20; try++)); do
        current="$(current_mode)"
        if [[ "$current" == "$previous" ]]; then
            ((stable += 1))
        else
            previous="$current"
            stable=1
        fi

        if ((stable >= STABLE_SAMPLES)); then
            printf '%s\n' "$current"
            return 0
        fi

        sleep "$POLL_INTERVAL"
    done

    printf '%s\n' "$current"
}

confirm_internal_only() {
    local try

    for ((try = 1; try <= DISCONNECT_GRACE_SAMPLES; try++)); do
        [[ "$(current_signature)" == "internal-only" ]] || return 1
        if ((try < DISCONNECT_GRACE_SAMPLES)); then
            sleep "$POLL_INTERVAL"
        fi
    done

    return 0
}

first_connected_external() {
    "$XRANDR_BIN" --query 2>/dev/null |
        awk '/ connected/ && $1 != "'"$INTERNAL"'" {print $1; exit}'
}

connected_non_internal_outputs() {
    "$XRANDR_BIN" --query 2>/dev/null |
        awk '/ connected/ && $1 != "'"$INTERNAL"'" {print $1}'
}

active_external_output() {
    "$I3MSG_BIN" -t get_outputs 2>/dev/null |
        "$JQ_BIN" -r '.[] | select(.active == true and .name != "'"$INTERNAL"'") | .name' |
        head -n 1
}

internal_output_active() {
    "$I3MSG_BIN" -t get_outputs 2>/dev/null |
        "$JQ_BIN" -e '.[] | select(.active == true and .name == "'"$INTERNAL"'")' >/dev/null
}

workspace_output() {
    local workspace_number="$1"

    "$I3MSG_BIN" -t get_workspaces 2>/dev/null |
        "$JQ_BIN" -r '.[] | select(.num == '"$workspace_number"') | .output' |
        head -n 1
}

mode_layout_matches() {
    local target_mode="$1"
    local target_external=""
    local output=""
    local i=""

    target_external="$(active_external_output)"

    if [[ "$target_mode" == "mobile" ]]; then
        internal_output_active || return 1
        [[ -z "$target_external" ]] || return 1

        for i in {1..9}; do
            output="$(workspace_output "$i")"
            [[ -z "$output" || "$output" == "$INTERNAL" ]] || return 1
        done
        return 0
    fi

    [[ -n "$target_external" ]] || return 1

    if [[ "$target_mode" == clamshell:* ]]; then
        internal_output_active && return 1
        for i in {1..9}; do
            output="$(workspace_output "$i")"
            [[ -z "$output" || "$output" == "$target_external" ]] || return 1
        done
        return 0
    fi

    internal_output_active || return 1
    for i in {1..8}; do
        output="$(workspace_output "$i")"
        [[ -z "$output" || "$output" == "$target_external" ]] || return 1
    done

    output="$(workspace_output 9)"
    [[ -z "$output" || "$output" == "$INTERNAL" ]] || return 1
    return 0
}

focused_workspace_name() {
    "$I3MSG_BIN" -t get_workspaces 2>/dev/null |
        "$JQ_BIN" -r '.[] | select(.focused == true) | .name' |
        head -n 1
}

ensure_workspaces_exist() {
    local i
    for i in {1..9}; do
        "$I3MSG_BIN" "workspace number $i" >/dev/null
    done
}

move_workspaces_docked() {
    local output="$1"
    local focused="$2"

    "$I3MSG_BIN" "\
workspace number 8; move workspace to output $output; \
workspace number 7; move workspace to output $output; \
workspace number 6; move workspace to output $output; \
workspace number 5; move workspace to output $output; \
workspace number 4; move workspace to output $output; \
workspace number 3; move workspace to output $output; \
workspace number 2; move workspace to output $output; \
workspace number 1; move workspace to output $output; \
workspace number 9; move workspace to output $INTERNAL; \
workspace $focused" >/dev/null
}

move_workspaces_mobile() {
    local focused="$1"

    "$I3MSG_BIN" "\
workspace number 1; move workspace to output $INTERNAL; \
workspace number 2; move workspace to output $INTERNAL; \
workspace number 3; move workspace to output $INTERNAL; \
workspace number 4; move workspace to output $INTERNAL; \
workspace number 5; move workspace to output $INTERNAL; \
workspace number 6; move workspace to output $INTERNAL; \
workspace number 7; move workspace to output $INTERNAL; \
workspace number 8; move workspace to output $INTERNAL; \
workspace number 9; move workspace to output $INTERNAL; \
workspace $focused" >/dev/null
}

move_workspaces_external_only() {
    local output="$1"
    local focused="$2"

    "$I3MSG_BIN" "\
workspace number 9; move workspace to output $output; \
workspace number 8; move workspace to output $output; \
workspace number 7; move workspace to output $output; \
workspace number 6; move workspace to output $output; \
workspace number 5; move workspace to output $output; \
workspace number 4; move workspace to output $output; \
workspace number 3; move workspace to output $output; \
workspace number 2; move workspace to output $output; \
workspace number 1; move workspace to output $output; \
workspace $focused" >/dev/null
}

turn_off_other_connected_outputs() {
    local keep_a="$1"
    local keep_b="${2:-}"
    local output=""

    while read -r output; do
        [[ -z "$output" ]] && continue
        if [[ "$output" != "$keep_a" && "$output" != "$keep_b" ]]; then
            run_retry "$XRANDR_APPLY_ATTEMPTS" "$XRANDR_BIN" --output "$output" --off
        fi
    done < <(connected_non_internal_outputs)
}

apply_mobile_layout() {
    run_retry "$XRANDR_APPLY_ATTEMPTS" \
        "$XRANDR_BIN" \
        --output "$INTERNAL" --auto --primary --pos 0x0
    turn_off_other_connected_outputs "$INTERNAL"
}

apply_docked_layout() {
    local external="$1"

    run_retry "$XRANDR_APPLY_ATTEMPTS" \
        "$XRANDR_BIN" \
        --output "$INTERNAL" --auto \
        --output "$external" --auto --primary --above "$INTERNAL"
    turn_off_other_connected_outputs "$INTERNAL" "$external"
}

apply_clamshell_layout() {
    local external="$1"

    run_retry "$XRANDR_APPLY_ATTEMPTS" \
        "$XRANDR_BIN" \
        --output "$external" --auto --primary \
        --output "$INTERNAL" --off
    turn_off_other_connected_outputs "$external"
}

main() {
    local previous_state=""
    local target_state=""
    local external=""
    local focused=""
    local actual_external=""
    local try

    if ! has_x_session; then
        log "DISPLAY CONNECTION: X session is not ready; skipping"
        exit 0
    fi

    if sleep_transition_in_progress; then
        log "DISPLAY CONNECTION: suspend transition in progress; skipping"
        exit 0
    fi

    if ! run_retry "$XRANDR_READY_ATTEMPTS" "$XRANDR_BIN" --query >/dev/null; then
        log "DISPLAY CONNECTION: xrandr is not ready; skipping"
        exit 0
    fi

    previous_state="$(read_state)"
    target_state="$(wait_for_stable_mode)"

    if [[ "$previous_state" == docked:* || "$previous_state" == clamshell:* ]] && [[ "$target_state" == "mobile" ]]; then
        if ! confirm_internal_only; then
            log "DISPLAY CONNECTION: transient disconnect ignored"
            exit 0
        fi
    fi

    if [[ "$target_state" == "$previous_state" ]]; then
        if mode_layout_matches "$target_state"; then
            log "DISPLAY CONNECTION: stable state unchanged ($target_state); no action"
            exit 0
        fi

        log "DISPLAY CONNECTION: stable mode $target_state but live layout drifted; reapplying"
    fi

    focused="$(focused_workspace_name)"
    focused="${focused:-9}"
    ensure_workspaces_exist

    if [[ "$target_state" == "mobile" ]]; then
        log "DISPLAY CONNECTION: applying mobile layout"
        apply_mobile_layout
        move_workspaces_mobile "$focused"
    else
        external="$(first_connected_external || true)"
        if [[ -z "$external" ]]; then
            log "DISPLAY CONNECTION: external signature seen but xrandr found none; skipping"
            exit 0
        fi

        if [[ "$target_state" == clamshell:* ]]; then
            log "DISPLAY CONNECTION: applying clamshell layout on $external"
            apply_clamshell_layout "$external"
        else
            log "DISPLAY CONNECTION: applying docked layout on $external"
            apply_docked_layout "$external"
        fi

        actual_external=""
        for ((try = 1; try <= I3_DISCOVERY_ATTEMPTS; try++)); do
            actual_external="$(active_external_output)"
            [[ -n "$actual_external" ]] && break
            sleep "$POLL_INTERVAL"
        done
        actual_external="${actual_external:-$external}"

        if [[ "$target_state" == clamshell:* ]]; then
            move_workspaces_external_only "$actual_external" "$focused"
        else
            move_workspaces_docked "$actual_external" "$focused"
        fi
    fi

    write_state "$target_state"
}

main "$@"
